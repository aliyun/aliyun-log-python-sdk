# -*- coding: utf-8 -*-
from typing import Dict, Optional

class QueriedLog:
    timestamp: int
    source: str
    contents: Dict[str, str]
    def __init__(self, timestamp: int, source: str, contents: Dict[str, str]) -> None: ...
    def get_time(self) -> int: ...
    def get_source(self) -> str: ...
    def get_contents(self) -> Dict[str, str]: ...
    def log_print(self) -> None: ...
